# EditorConfig — consistente opmaak over editors heen. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# .NET / C#
[*.{cs,csx}]
indent_size = 4

[*.{csproj,props,targets}]
indent_size = 2

# Web / config
[*.{ts,tsx,js,jsx,json,css,html,yml,yaml}]
indent_size = 2

# Markdown: trailing whitespace kan een regeleinde betekenen.
[*.md]
trim_trailing_whitespace = false

# Bash-scripts: LF verplicht.
[*.sh]
end_of_line = lf

# PowerShell op Windows: CRLF.
[*.ps1]
end_of_line = crlf

# --- C#-stijl (suggesties; niet build-blokkerend) ---
[*.cs]
dotnet_sort_system_directives_first = true
dotnet_style_namespace_match_folder = true
csharp_using_directive_placement = outside_namespace:suggestion
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_prefer_braces = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
dotnet_style_readonly_field = true:suggestion
