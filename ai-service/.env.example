# Kopieer naar .env en vul je echte sleutel in. Commit NOOIT de echte .env.

# Anthropic Claude API — nodig vanaf Fase 2 Dag 4 (AI-extractie naar JSON).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Model voor de extractie (overschrijfbaar). Standaard het meest capabele model;
# zet op claude-sonnet-5 voor een goedkopere/snellere optie bij hoog volume.
ANTHROPIC_MODEL=claude-opus-4-8
